{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Patina Dev",
  "mainBinaryName": "PatinaDev",
  "version": "1.5.1",
  "identifier": "com.timetracker.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Patina Dev",
        "width": 1100,
        "height": 736,
        "minWidth": 900,
        "minHeight": 636,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:timetracker.db"
      ]
    },
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/Ceceliaee/patina/releases/latest/download/latest.json",
        "https://pub-ad4b539442124a3287529c9435f053ba.r2.dev/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ4ODMzNkI5M0Q3OTU2QkMKUldTOFZuazl1VGFEU0RDakI2UEF1SUlyNGxDVnZVRTl1TEFUK0Rmei9xZVlYR3R3SnprRXNCWVoK"
    }
  }
}
