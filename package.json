{
  "name": "time-tracker",
  "private": true,
  "version": "0.4.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "node --experimental-strip-types --experimental-specifier-resolution=node tests/trackingLifecycle.test.ts",
    "test:replay": "node --experimental-strip-types --experimental-specifier-resolution=node tests/trackingReplay.test.ts",
    "test:update": "node --experimental-strip-types --experimental-specifier-resolution=node tests/updateViewModel.test.ts",
    "test:settings": "node --experimental-strip-types --experimental-specifier-resolution=node tests/settingsPageState.test.ts",
    "test:widget": "node --experimental-strip-types --experimental-specifier-resolution=node tests/widgetViewModel.test.ts",
    "test:classification": "node --experimental-strip-types --experimental-specifier-resolution=node tests/classificationDraftState.test.ts",
    "test:persistence": "node --experimental-strip-types --experimental-specifier-resolution=node tests/persistenceTransaction.test.ts",
    "test:interaction": "node --experimental-strip-types --experimental-specifier-resolution=node tests/interactionFlows.test.ts",
    "check:naming": "node --experimental-strip-types scripts/check-naming-boundaries.ts",
    "check:frontend": "npm test && npm run test:replay && npm run test:update && npm run test:settings && npm run test:widget && npm run test:classification && npm run test:persistence && npm run test:interaction && npm run build",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml --quiet && cargo test --manifest-path src-tauri/Cargo.toml --quiet",
    "check:full": "npm run check && npm run check:rust",
    "check": "npm run check:naming && npm run check:frontend",
    "perf:history-read-model": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/perf/history-read-model-benchmark.ts",
    "perf:dashboard-read-model": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/perf/dashboard-read-model-benchmark.ts",
    "perf:startup-bootstrap": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/perf/startup-bootstrap-benchmark.ts",
    "release:sync-version": "node --experimental-strip-types scripts/release.ts sync-version",
    "release:validate-changelog": "node --experimental-strip-types scripts/release.ts validate-changelog",
    "release:notes": "node --experimental-strip-types scripts/release.ts print-release-notes",
    "release:latest": "node --experimental-strip-types scripts/release.ts write-latest-json",
    "release:prepare-assets": "node --experimental-strip-types scripts/release.ts prepare-release-assets",
    "release:check": "npm run check:full && npm run release:validate-changelog",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-sql": "^2.3.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
