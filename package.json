{
  "name": "patina",
  "private": true,
  "version": "1.8.5",
  "type": "module",
  "engines": {
    "node": "24.18.0",
    "npm": "11.16.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": "11.16.0",
      "onFail": "error"
    }
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "npm run test:fast:covered && npm run test:fast:remaining",
    "test:tracking": "node --experimental-strip-types --experimental-specifier-resolution=node tests/trackingLifecycle.test.ts",
    "test:replay": "node --experimental-strip-types --experimental-specifier-resolution=node tests/trackingReplay.test.ts",
    "test:history-timeline": "node --experimental-strip-types --experimental-specifier-resolution=node tests/historyTimelineViewModel.test.ts && node --experimental-strip-types --experimental-specifier-resolution=node tests/historyWebActivityViewModel.test.ts && node --experimental-strip-types --experimental-specifier-resolution=node tests/historyReadModel.test.ts && node --experimental-strip-types --experimental-specifier-resolution=node tests/historyFormatting.test.ts",
    "test:update": "node --experimental-strip-types --experimental-specifier-resolution=node tests/updateViewModel.test.ts",
    "test:settings": "node --experimental-strip-types --experimental-specifier-resolution=node tests/settingsPageState.test.ts",
    "test:import": "node --experimental-strip-types --experimental-specifier-resolution=node tests/importDataContract.test.ts && node --experimental-strip-types --experimental-specifier-resolution=node tests/nativeSessionPrecedence.test.ts",
    "test:widget": "node --experimental-strip-types --experimental-specifier-resolution=node tests/widgetViewModel.test.ts",
    "test:classification": "node --experimental-strip-types --experimental-specifier-resolution=node tests/classificationDraftState.test.ts && node --experimental-strip-types --experimental-specifier-resolution=node tests/classificationAppCatalog.test.ts",
    "test:icon-colors": "node --experimental-strip-types --experimental-specifier-resolution=node tests/iconThemeColors.test.ts",
    "test:dashboard-icons": "node --experimental-strip-types --experimental-specifier-resolution=node tests/dashboardIconRuntimeCache.test.ts",
    "test:data": "node --experimental-strip-types --experimental-specifier-resolution=node tests/dataReadModel.test.ts && node --experimental-strip-types --experimental-specifier-resolution=node tests/dataFirstPaintScheduler.test.ts && node --experimental-strip-types --experimental-specifier-resolution=node tests/dataAppSearch.test.ts",
    "test:data-range": "node --experimental-strip-types --experimental-specifier-resolution=node tests/dataTrendRange.test.ts",
    "test:data-chart": "node --experimental-strip-types --experimental-specifier-resolution=node tests/dataChartInteraction.test.ts",
    "test:persistence": "node --experimental-strip-types --experimental-specifier-resolution=node tests/persistenceTransaction.test.ts && node --experimental-strip-types --experimental-specifier-resolution=node tests/activityReadModelGateway.test.ts",
    "test:dashboard-snapshot": "node --experimental-strip-types --experimental-specifier-resolution=node tests/dashboardSnapshotLoader.test.ts",
    "test:fast:covered": "npm run test:tracking && npm run test:replay && npm run test:history-timeline && npm run test:persistence && npm run test:dashboard-snapshot",
    "test:fast:remaining": "npm run test:update && npm run test:settings && npm run test:import && npm run test:widget && npm run test:classification && npm run test:icon-colors && npm run test:dashboard-icons && npm run test:data-range && npm run test:data && npm run test:data-chart && npm run test:interaction && npm run test:release && npm run test:export && npm run test:pr-intake && npm run test:warmup && npm run test:background-return && npm run test:tools && npm run test:toast && npm run test:preload && npm run test:tracker-health && npm run test:ui-smoke",
    "test:coverage": "c8 --all --clean --reporter=text --reporter=json-summary --report-dir=artifacts/coverage --include=src/app/hooks/trackingDataChangedPolicy.ts --include=src/app/hooks/trackingDataChangedRuntime.ts --include=src/features/dashboard/services/dashboardReadModel.ts --include=src/features/history/services/historyReadModel.ts --include=src/platform/persistence/sqliteTransactions.ts --include=src/platform/persistence/commandError.ts --check-coverage --lines=80 --functions=80 --branches=75 --statements=80 npm run test:fast:covered",
    "test:mutation": "node --experimental-strip-types scripts/check-critical-mutations.ts",
    "test:interaction": "node --experimental-strip-types --experimental-specifier-resolution=node tests/interactionFlows.test.ts",
    "test:release": "node --experimental-strip-types --experimental-specifier-resolution=node tests/releasePolicy.test.ts",
    "test:export": "node --experimental-strip-types --experimental-specifier-resolution=node tests/exportRange.test.ts && node --experimental-strip-types --experimental-specifier-resolution=node tests/exportFieldContract.test.ts",
    "test:pr-intake": "node --experimental-strip-types --experimental-specifier-resolution=node tests/prIntakeGate.test.ts",
    "test:warmup": "node --experimental-strip-types --experimental-specifier-resolution=node tests/startupWarmupService.test.ts",
    "test:background-return": "node --experimental-strip-types --experimental-specifier-resolution=node tests/backgroundReturnHomePolicy.test.ts",
    "test:tools": "node --experimental-strip-types --experimental-specifier-resolution=node tests/toolsRuntime.test.ts",
    "test:toast": "node --experimental-strip-types --experimental-specifier-resolution=node tests/toastQueueRuntime.test.ts",
    "test:preload": "node --experimental-strip-types --experimental-specifier-resolution=node tests/viewChunkPreloadService.test.ts",
    "test:tracker-health": "node --experimental-strip-types --experimental-specifier-resolution=node tests/trackerHealthPollingService.test.ts",
    "test:ui-smoke": "node --experimental-strip-types --experimental-specifier-resolution=node tests/uiSmoke.test.ts",
    "test:ui-browser-smoke": "node --experimental-strip-types --experimental-specifier-resolution=node tests/uiBrowserSmoke.test.ts",
    "test:tauri-runtime-smoke": "node --experimental-strip-types --experimental-specifier-resolution=node tests/tauriRuntimeSmoke.test.ts",
    "check:types": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.quality.json",
    "check:lint": "eslint . --max-warnings 0",
    "check:naming": "node --experimental-strip-types scripts/check-naming-boundaries.ts",
    "check:architecture": "node --experimental-strip-types scripts/check-architecture-boundaries.ts",
    "check:architecture:self-test": "node --experimental-strip-types scripts/check-architecture-boundaries.ts --self-test",
    "check:rust-boundaries": "node --experimental-strip-types scripts/check-rust-boundaries.ts",
    "check:rust-boundaries:self-test": "node --experimental-strip-types scripts/check-rust-boundaries.ts --self-test",
    "check:ipc-contracts": "node --experimental-strip-types scripts/check-ipc-contracts.ts",
    "check:ipc-contracts:self-test": "node --experimental-strip-types scripts/check-ipc-contracts.ts --self-test",
    "check:hotspots": "node --experimental-strip-types scripts/check-quality-hotspot-baseline.ts",
    "check:quiet-pro-style-debt": "node --experimental-strip-types scripts/check-quiet-pro-style-debt.ts",
    "check:test-governance": "node --experimental-strip-types scripts/check-test-suite-governance.ts",
    "check:test-governance:self-test": "node --experimental-strip-types scripts/check-test-suite-governance.ts --self-test",
    "check:pr-intake": "node --experimental-strip-types scripts/check-pr-intake.ts",
    "check:bundle": "node --experimental-strip-types scripts/check-bundle-budget.ts",
    "check:dependencies": "node --experimental-strip-types scripts/audit-dependencies.ts",
    "quality:hotspots": "node --experimental-strip-types scripts/report-code-quality-hotspots.ts",
    "check:tests": "npm run test:coverage && npm run test:fast:remaining && npm run test:mutation && npm run test:ui-browser-smoke",
    "check:frontend": "npm run build && npm run check:bundle",
    "check:rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --locked -- -D warnings",
    "check:rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check",
    "check:rust": "npm run check:rust-boundaries:self-test && npm run check:rust-boundaries && npm run check:rust:fmt && cargo check --manifest-path src-tauri/Cargo.toml --locked --quiet && cargo test --manifest-path src-tauri/Cargo.toml --locked --quiet && npm run check:rust:clippy",
    "check:full": "npm run check && npm run check:rust && npm run check:dependencies",
    "check": "npm run check:types && npm run check:lint && npm run check:naming && npm run check:architecture:self-test && npm run check:architecture && npm run check:ipc-contracts:self-test && npm run check:ipc-contracts && npm run check:hotspots && npm run check:quiet-pro-style-debt && npm run check:test-governance:self-test && npm run check:test-governance && npm run check:tests && npm run check:frontend",
    "perf:history-read-model": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/perf/history-read-model-benchmark.ts",
    "perf:dashboard-read-model": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/perf/dashboard-read-model-benchmark.ts",
    "perf:data-read-model": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/perf/data-read-model-benchmark.ts",
    "perf:data-history-browser": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/perf/data-history-browser-benchmark.ts",
    "perf:sqlite-query-plan": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/perf/sqlite-query-plan-benchmark.ts",
    "perf:startup-bootstrap": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/perf/startup-bootstrap-benchmark.ts",
    "perf:classification-app-catalog": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/perf/classification-app-catalog-benchmark.ts",
    "perf:activity-read-model": "node --expose-gc --experimental-strip-types --experimental-specifier-resolution=node scripts/perf/activity-read-model-benchmark.ts",
    "perf:stable": "node --experimental-strip-types scripts/perf/stable-benchmark-suite.ts",
    "release:sync-version": "node --experimental-strip-types scripts/release.ts sync-version",
    "release:validate-version-files": "node --experimental-strip-types scripts/release.ts validate-version-files",
    "release:validate-changelog": "node --experimental-strip-types scripts/release.ts validate-changelog",
    "release:notes": "node --experimental-strip-types scripts/release.ts print-release-notes",
    "release:latest": "node --experimental-strip-types scripts/release.ts write-latest-json",
    "release:prepare-assets": "node --experimental-strip-types scripts/release.ts prepare-release-assets",
    "release:check": "npm run check:full && npm run release:validate-changelog",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-sql": "^2.3.2",
    "esbuild": "0.28.1",
    "lucide-react": "^1.7.0",
    "postcss": "8.5.19",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@tauri-apps/cli": "^2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "6.0.3",
    "c8": "11.0.0",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.64.0",
    "vite": "8.1.4"
  }
}
