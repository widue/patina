{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "noEmit": true,
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*.d.ts", "scripts/**/*.ts", "tests/**/*.ts", "vite.config.ts"],
  "exclude": ["node_modules", "dist", "src-tauri/target"]
}
